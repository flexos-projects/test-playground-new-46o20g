{
  "rewrites": [
    { "source": "/preview/:path*", "destination": "/pages/:path*" },
    { "source": "/preview", "destination": "/index.html" },
    { "source": "/pages/:path*", "destination": "/pages/:path*" },
    { "source": "/shared/:path*", "destination": "/shared/:path*" },
    { "source": "/placeholder", "destination": "/placeholder.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
